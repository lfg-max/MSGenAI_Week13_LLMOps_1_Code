# ==========================================
# AZURE ARTIFACT NAMES & LOCATIONS CONFIG
# ==========================================

# --- General Settings ---
RESOURCE_GROUP="rgrp"
RG_LOCATION="eastus2" 

# --- Storage Account ---
STORAGE_ACCOUNT_NAME="nrastorageacc"
CONTAINER_NAME="nra-supplychain-container"
LOCATION_STORAGE="eastus2"
STORAGE_SKU="Standard_LRS"

# --- AI Search Service (Vector Search) ---
SEARCH_SERVICE_NAME="nra-ai-search"
LOCATION_SEARCH="eastus"
SEARCH_SKU="free"

# --- Container Registry ---
ACR_NAME="nracontainerregistry"
LOCATION_ACR="eastus"
ACR_SKU="Basic"

# --- Web App & App Service Plan ---
APP_SERVICE_PLAN_NAME="nra-app-plan"
WEB_APP_NAME="nra-webapp"
LOCATION_WEBAPP="swedencentral"
WEBAPP_SKU="B1"

# --- Docker Image Settings ---
IMAGE_NAME="supplychain-llmops"
IMAGE_TAG="latest"

# --- Local Data Settings ---
LOCAL_DATA_FOLDER="./data"
